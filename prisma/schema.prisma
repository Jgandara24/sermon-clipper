generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  DEV       @map("dev")
  EMAIL_OTP @map("email_otp")
  GOOGLE    @map("google")

  @@map("auth_provider")
}

enum WorkspaceRole {
  OWNER    @map("owner")
  ADMIN    @map("admin")
  EDITOR   @map("editor")
  APPROVER @map("approver")
  VIEWER   @map("viewer")

  @@map("workspace_role")
}

enum MemberStatus {
  ACTIVE  @map("active")
  INVITED @map("invited")

  @@map("member_status")
}

enum WorkspaceInvitationStatus {
  PENDING  @map("pending")
  ACCEPTED @map("accepted")
  REVOKED  @map("revoked")
  EXPIRED  @map("expired")

  @@map("workspace_invitation_status")
}

enum SourceOrigin {
  UPLOAD @map("upload")
  URL    @map("url")

  @@map("source_origin")
}

enum ProjectStatus {
  DRAFT      @map("draft")
  QUEUED     @map("queued")
  PROCESSING @map("processing")
  READY      @map("ready")
  FAILED     @map("failed")
  CANCELED   @map("canceled")

  @@map("project_status")
}

enum ProcessingJobType {
  FINALIZE       @map("finalize")
  PROBE          @map("probe")
  TRANSCRIBE     @map("transcribe")
  ANALYZE        @map("analyze")
  GENERATE_CLIPS @map("generate_clips")
  PREVIEW_RENDER @map("preview_render")
  EXPORT         @map("export")
  CLEANUP        @map("cleanup")

  @@map("processing_job_type")
}

enum ProcessingJobState {
  QUEUED    @map("queued")
  RUNNING   @map("running")
  WAITING   @map("waiting")
  SUCCEEDED @map("succeeded")
  FAILED    @map("failed")
  CANCELED  @map("canceled")
  RETRYING  @map("retrying")
  EXPIRED   @map("expired")

  @@map("processing_job_state")
}

enum LedgerKind {
  GRANT      @map("grant")
  PROCESSING @map("processing")
  EXPORT     @map("export")
  REFUND     @map("refund")
  ADJUSTMENT @map("adjustment")

  @@map("ledger_kind")
}

enum GeneratedClipStatus {
  SUGGESTED @map("suggested")
  KEPT      @map("kept")
  HIDDEN    @map("hidden")

  @@map("generated_clip_status")
}

enum ExportPreset {
  MP4_1080 @map("mp4_1080")

  @@map("export_preset")
}

enum ClipApprovalState {
  DRAFT             @map("draft")
  IN_REVIEW         @map("in_review")
  APPROVED          @map("approved")
  CHANGES_REQUESTED @map("changes_requested")

  @@map("clip_approval_state")
}

enum NotificationChannel {
  EMAIL @map("email")
  SMS   @map("sms")

  @@map("notification_channel")
}

enum NotificationStatus {
  PENDING @map("pending")
  SENT    @map("sent")
  FAILED  @map("failed")
  SKIPPED @map("skipped")

  @@map("notification_status")
}

model User {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String       @unique
  name         String?
  authProvider AuthProvider @default(DEV) @map("auth_provider")
  locale       String       @default("en")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  ownedWorkspaces      Workspace[]           @relation("WorkspaceOwner")
  memberships          WorkspaceMember[]
  sentWorkspaceInvites WorkspaceInvitation[] @relation("WorkspaceInvitationInviter")
  clipEdits            ClipEdit[]
  clipApprovalRequests ClipApproval[]
  authSessions         AuthSession[]

  @@map("users")
}

model AuthSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model EmailOtpChallenge {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                String
  codeHash             String             @map("code_hash")
  expiresAt            DateTime           @map("expires_at")
  consumedAt           DateTime?          @map("consumed_at")
  attempts             Int                @default(0)
  deliveryStatus       NotificationStatus @default(PENDING) @map("delivery_status")
  deliveryProvider     String?            @map("delivery_provider")
  deliveryErrorMessage String?            @map("delivery_error_message")
  sentAt               DateTime?          @map("sent_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  @@index([email, createdAt])
  @@index([expiresAt])
  @@index([deliveryStatus])
  @@map("email_otp_challenges")
}

model Workspace {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                     String
  ownerId                  String    @map("owner_id") @db.Uuid
  planCode                 String    @default("free") @map("plan_code")
  minuteBalance            Decimal   @default(60) @map("minute_balance") @db.Decimal(10, 2)
  stripeCustomerId         String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId     String?   @unique @map("stripe_subscription_id")
  stripeSubscriptionStatus String?   @map("stripe_subscription_status")
  stripePriceId            String?   @map("stripe_price_id")
  stripeCurrentPeriodEnd   DateTime? @map("stripe_current_period_end")
  storageUsedBytes         BigInt    @default(0) @map("storage_used_bytes")
  settings                 Json      @default("{}")
  externalRefs             Json      @default("{}") @map("external_refs")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  owner                   User                     @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  members                 WorkspaceMember[]
  invitations             WorkspaceInvitation[]
  sourceVideos            SourceVideo[]
  projects                Project[]
  usageLedger             UsageLedger[]
  generatedClips          GeneratedClip[]
  clipScores              ClipScore[]
  exportJobs              ExportJob[]
  scriptureReferences     ScriptureReference[]
  brandTemplates          BrandTemplate[]
  clipApprovals           ClipApproval[]
  approvalNotifications   ApprovalNotification[]
  clipApprovalAuditEvents ClipApprovalAuditEvent[]
  operationalEvents       OperationalEvent[]
  billingPeriodCredits    BillingPeriodCredit[]

  @@index([ownerId])
  @@map("workspaces")
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now()) @map("processed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("stripe_webhook_events")
}

model BillingPeriodCredit {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId          String   @map("workspace_id") @db.Uuid
  stripeInvoiceId      String   @unique @map("stripe_invoice_id")
  stripeSubscriptionId String   @map("stripe_subscription_id")
  planCode             String   @map("plan_code")
  minutesGranted       Decimal  @map("minutes_granted") @db.Decimal(10, 2)
  ledgerId             String?  @map("ledger_id") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ledger    UsageLedger? @relation(fields: [ledgerId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([stripeSubscriptionId])
  @@map("billing_period_credits")
}

model WorkspaceMember {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole
  status      MemberStatus  @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id                   String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId          String                    @map("workspace_id") @db.Uuid
  email                String
  role                 WorkspaceRole
  status               WorkspaceInvitationStatus @default(PENDING)
  tokenHash            String                    @unique @map("token_hash")
  deliveryStatus       NotificationStatus        @default(PENDING) @map("delivery_status")
  deliveryProvider     String?                   @map("delivery_provider")
  deliveryErrorMessage String?                   @map("delivery_error_message")
  invitedByUserId      String                    @map("invited_by_user_id") @db.Uuid
  expiresAt            DateTime                  @map("expires_at")
  acceptedAt           DateTime?                 @map("accepted_at")
  revokedAt            DateTime?                 @map("revoked_at")
  createdAt            DateTime                  @default(now()) @map("created_at")
  updatedAt            DateTime                  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("WorkspaceInvitationInviter", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@index([workspaceId, status, createdAt])
  @@index([email, status])
  @@index([expiresAt])
  @@map("workspace_invitations")
}

model SourceVideo {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId    String       @map("workspace_id") @db.Uuid
  origin         SourceOrigin
  originUrl      String?      @map("origin_url")
  filename       String?
  durationS      Decimal?     @map("duration_s") @db.Decimal(10, 2)
  sizeBytes      BigInt?      @map("size_bytes")
  width          Int?
  height         Int?
  fps            Decimal?     @db.Decimal(8, 3)
  storageKey     String?      @map("storage_key")
  audioKey       String?      @map("audio_key")
  thumbnailKey   String?      @map("thumbnail_key")
  language       String?
  srtOverrideKey String?      @map("srt_override_key")
  copyrightAckAt DateTime?    @map("copyright_ack_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects   Project[]
  transcript Transcript?

  @@index([workspaceId])
  @@map("source_videos")
}

model Transcript {
  id            String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sourceVideoId String                   @unique @map("source_video_id") @db.Uuid
  language      String
  provider      String
  fullText      String                   @map("full_text")
  // Generated column (to_tsvector over full_text) + GIN index, added via raw SQL in the migration.
  searchVector  Unsupported("tsvector")? @map("search_vector")
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")

  sourceVideo SourceVideo         @relation(fields: [sourceVideoId], references: [id], onDelete: Cascade)
  segments    TranscriptSegment[]

  @@map("transcripts")
}

// word_timestamps modeled as `words` jsonb on the segment (guide §6 MVP alternative) rather than
// a separate table — see DECISIONS.md.
model TranscriptSegment {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transcriptId String   @map("transcript_id") @db.Uuid
  idx          Int
  startMs      Int      @map("start_ms")
  endMs        Int      @map("end_ms")
  text         String
  speakerLabel String?  @map("speaker_label")
  words        Json     @default("[]")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  transcript Transcript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  @@index([transcriptId, startMs])
  @@map("transcript_segments")
}

model Project {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId      String        @map("workspace_id") @db.Uuid
  name             String
  sourceVideoId    String?       @map("source_video_id") @db.Uuid
  status           ProjectStatus @default(DRAFT)
  processingConfig Json          @default("{}") @map("processing_config")
  folder           String?
  series           String?
  speaker          String?
  expiresAt        DateTime?     @map("expires_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceVideo         SourceVideo?         @relation(fields: [sourceVideoId], references: [id], onDelete: SetNull)
  processingJobs      ProcessingJob[]
  usageLedger         UsageLedger[]
  generatedClips      GeneratedClip[]
  scriptureReferences ScriptureReference[]

  @@index([workspaceId])
  @@index([sourceVideoId])
  @@map("projects")
}

model ProcessingJob {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId        String             @map("project_id") @db.Uuid
  type             ProcessingJobType
  state            ProcessingJobState @default(QUEUED)
  progress         Int                @default(0)
  attempt          Int                @default(0)
  idempotencyKey   String             @unique @map("idempotency_key")
  errorCode        String?            @map("error_code")
  errorMessageUser String?            @map("error_message_user")
  minutesReserved  Decimal?           @map("minutes_reserved") @db.Decimal(10, 2)
  runAfter         DateTime           @default(now()) @map("run_after")
  workerId         String?            @map("worker_id")
  heartbeatAt      DateTime?          @map("heartbeat_at")
  maxAttempts      Int                @default(3) @map("max_attempts")
  lastErrorAt      DateTime?          @map("last_error_at")
  staleRecoveredAt DateTime?          @map("stale_recovered_at")
  startedAt        DateTime?          @map("started_at")
  finishedAt       DateTime?          @map("finished_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  usageLedger UsageLedger[]

  @@index([state, type, runAfter])
  @@index([state, heartbeatAt])
  @@index([projectId])
  @@map("processing_jobs")
}

model UsageLedger {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String     @map("workspace_id") @db.Uuid
  kind         LedgerKind
  projectId    String?    @map("project_id") @db.Uuid
  minutesDelta Decimal    @map("minutes_delta") @db.Decimal(10, 2)
  balanceAfter Decimal    @map("balance_after") @db.Decimal(10, 2)
  jobId        String?    @map("job_id") @db.Uuid
  note         String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project              Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  job                  ProcessingJob?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  billingPeriodCredits BillingPeriodCredit[]

  @@index([workspaceId, createdAt])
  @@index([projectId])
  @@map("usage_ledger")
}

model GeneratedClip {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String              @map("workspace_id") @db.Uuid
  projectId   String              @map("project_id") @db.Uuid
  rank        Int
  startMs     Int                 @map("start_ms")
  endMs       Int                 @map("end_ms")
  title       String
  hookText    String?             @map("hook_text")
  summary     String
  status      GeneratedClipStatus @default(SUGGESTED)
  liked       Boolean?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  score               ClipScore?
  edits               ClipEdit[]
  exportJobs          ExportJob[]
  scriptureReferences ScriptureReference[]
  approvals           ClipApproval[]

  @@unique([projectId, rank])
  @@index([workspaceId])
  @@index([projectId])
  @@map("generated_clips")
}

// Editor state is one versioned JSON document per save (guide §12). Each save creates a new
// row rather than updating in place, so the full edit history is preserved and optimistic
// concurrency (reject a save whose baseVersion is stale) is just "does this version already
// exist" — no separate locking needed.
model ClipEdit {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clipId      String   @map("clip_id") @db.Uuid
  version     Int
  editorState Json     @map("editor_state")
  isAutosave  Boolean  @default(false) @map("is_autosave")
  savedBy     String?  @map("saved_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  clip        GeneratedClip @relation(fields: [clipId], references: [id], onDelete: Cascade)
  savedByUser User?         @relation(fields: [savedBy], references: [id], onDelete: SetNull)

  @@unique([clipId, version])
  @@map("clip_edits")
}

model ClipScore {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  clipId       String   @unique @map("clip_id") @db.Uuid
  total        Int
  subscores    Json
  modelVersion String   @map("model_version")
  excerpt      String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clip      GeneratedClip @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("clip_scores")
}

// Deliberately a separate table from processing_jobs (guide §6): exports are per-clip, and a
// project's several clips can each have independent, concurrent export histories. state reuses
// ProcessingJobState per the guide's "(same enum as processing_jobs)" note rather than a new enum.
model ExportJob {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clipId           String             @map("clip_id") @db.Uuid
  workspaceId      String             @map("workspace_id") @db.Uuid
  preset           ExportPreset       @default(MP4_1080)
  state            ProcessingJobState @default(QUEUED)
  progress         Int                @default(0)
  attempt          Int                @default(0)
  idempotencyKey   String             @unique @map("idempotency_key")
  filename         String
  errorCode        String?            @map("error_code")
  errorMessageUser String?            @map("error_message_user")
  minutesCharged   Decimal?           @map("minutes_charged") @db.Decimal(10, 2)
  outputFileId     String?            @unique @map("output_file_id") @db.Uuid
  runAfter         DateTime           @default(now()) @map("run_after")
  workerId         String?            @map("worker_id")
  heartbeatAt      DateTime?          @map("heartbeat_at")
  maxAttempts      Int                @default(3) @map("max_attempts")
  lastErrorAt      DateTime?          @map("last_error_at")
  staleRecoveredAt DateTime?          @map("stale_recovered_at")
  startedAt        DateTime?          @map("started_at")
  finishedAt       DateTime?          @map("finished_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  clip       GeneratedClip @relation(fields: [clipId], references: [id], onDelete: Cascade)
  workspace  Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  outputFile ExportedFile? @relation(fields: [outputFileId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([state, runAfter])
  @@index([state, heartbeatAt])
  @@index([clipId])
  @@map("export_jobs")
}

model ExportedFile {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storageKey        String   @map("storage_key")
  bytes             BigInt
  width             Int
  height            Int
  checksum          String
  downloadExpiresAt DateTime @map("download_expires_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  exportJob ExportJob?

  @@map("exported_files")
}

model WorkerHeartbeat {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workerId    String   @unique @map("worker_id")
  hostname    String?
  pid         Int?
  startedAt   DateTime @map("started_at")
  lastSeenAt  DateTime @map("last_seen_at")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([lastSeenAt])
  @@map("worker_heartbeats")
}

model ScriptureReference {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  clipId       String?  @map("clip_id") @db.Uuid
  detectedText String   @map("detected_text")
  normalized   String
  book         String
  chapterStart Int      @map("chapter_start")
  verseStart   Int?     @map("verse_start")
  chapterEnd   Int?     @map("chapter_end")
  verseEnd     Int?     @map("verse_end")
  confidence   Decimal  @default(0.80) @db.Decimal(4, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clip      GeneratedClip? @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
  @@index([clipId])
  @@map("scripture_references")
}

model BrandTemplate {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  name            String
  churchName      String   @map("church_name")
  speakerName     String?  @map("speaker_name")
  primaryColor    String   @default("#0f766e") @map("primary_color")
  accentColor     String   @default("#facc15") @map("accent_color")
  captionPresetId String   @default("clean") @map("caption_preset_id")
  lowerThird      Json     @default("{}") @map("lower_third")
  isDefault       Boolean  @default(false) @map("is_default")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("brand_templates")
}

model ClipApproval {
  id                      String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId             String            @map("workspace_id") @db.Uuid
  clipId                  String            @map("clip_id") @db.Uuid
  state                   ClipApprovalState @default(DRAFT)
  reviewToken             String            @unique @map("review_token")
  reviewTokenExpiresAt    DateTime          @map("review_token_expires_at")
  reviewTokenRevokedAt    DateTime?         @map("review_token_revoked_at")
  reviewTokenLastViewedAt DateTime?         @map("review_token_last_viewed_at")
  requesterId             String?           @map("requester_id") @db.Uuid
  approverName            String?           @map("approver_name")
  comment                 String?
  decidedAt               DateTime?         @map("decided_at")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  workspace     Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clip          GeneratedClip            @relation(fields: [clipId], references: [id], onDelete: Cascade)
  requester     User?                    @relation(fields: [requesterId], references: [id], onDelete: SetNull)
  notifications ApprovalNotification[]
  auditEvents   ClipApprovalAuditEvent[]

  @@unique([clipId])
  @@index([workspaceId])
  @@index([reviewTokenExpiresAt])
  @@map("clip_approvals")
}

model ApprovalNotification {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  approvalId        String              @map("approval_id") @db.Uuid
  workspaceId       String              @map("workspace_id") @db.Uuid
  channel           NotificationChannel
  recipient         String
  provider          String
  status            NotificationStatus  @default(PENDING)
  errorMessage      String?             @map("error_message")
  providerMessageId String?             @map("provider_message_id")
  metadata          Json                @default("{}")
  sentAt            DateTime?           @map("sent_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  approval  ClipApproval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([approvalId])
  @@index([workspaceId])
  @@index([status])
  @@map("approval_notifications")
}

model ClipApprovalAuditEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  approvalId  String   @map("approval_id") @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  eventType   String   @map("event_type")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  approval  ClipApproval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([approvalId])
  @@index([workspaceId])
  @@index([eventType])
  @@map("clip_approval_audit_events")
}

model OperationalEvent {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String?  @map("workspace_id") @db.Uuid
  category    String
  eventType   String   @map("event_type")
  severity    String   @default("info")
  message     String
  projectId   String?  @map("project_id") @db.Uuid
  jobId       String?  @map("job_id") @db.Uuid
  exportJobId String?  @map("export_job_id") @db.Uuid
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([category, createdAt])
  @@index([severity, createdAt])
  @@index([projectId])
  @@index([jobId])
  @@index([exportJobId])
  @@map("operational_events")
}
