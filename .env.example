DATABASE_URL="postgresql://sermon_clipper:sermon_clipper@localhost:5432/sermon_clipper?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Required in production for signed upload, media, and download URLs. Use at least 32 random
# characters and keep it stable across web and worker processes.
# MEDIA_URL_SECRET="change-me-to-a-long-random-production-secret"

# Required for production multi-instance or self-hosted deployments so Server Action references
# remain decryptable across rolling deploys.
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="base64-32-byte-secret"

# Recommended in production so /api/health and launch evidence can prove which commit is deployed.
# Common hosts may also provide VERCEL_GIT_COMMIT_SHA, RAILWAY_GIT_COMMIT_SHA, RENDER_GIT_COMMIT,
# HEROKU_SLUG_COMMIT, GIT_COMMIT_SHA, COMMIT_SHA, or SOURCE_VERSION automatically.
# SERMON_CLIPPER_COMMIT_SHA="git-sha"

# Storage provider. Use "local" for development and "s3" for AWS S3, Cloudflare R2, or any
# S3-compatible object store in production.
STORAGE_PROVIDER="local"

# Local-disk storage root for the dev-only StorageProvider. Defaults to ./.data/storage if unset.
STORAGE_LOCAL_ROOT=".data/storage"

# Required when STORAGE_PROVIDER=s3. For Cloudflare R2, set STORAGE_S3_REGION="auto" and
# STORAGE_S3_ENDPOINT to the account-specific R2 endpoint.
# STORAGE_S3_BUCKET="sermon-clipper-production"
# STORAGE_S3_REGION="auto"
# STORAGE_S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# STORAGE_S3_ACCESS_KEY_ID="..."
# STORAGE_S3_SECRET_ACCESS_KEY="..."
# STORAGE_S3_FORCE_PATH_STYLE="true"

# Required in production. Signs short-lived media and upload URLs. Local development falls back to
# a dev-only secret if this is unset.
MEDIA_URL_SECRET="replace-with-a-long-random-secret"

# Email OTP sign-in and approval notifications. SENDGRID_API_KEY plus AUTH_EMAIL_FROM or
# NOTIFICATIONS_FROM_EMAIL is required for production sign-in. If an approval reviewer recipient is
# supplied but credentials are missing, the notification attempt is recorded as skipped.
# SENDGRID_API_KEY="SG..."
# AUTH_EMAIL_FROM="auth@example.com"
# AUTH_EMAIL_FROM_NAME="Sermon Clipper"
# NOTIFICATIONS_FROM_EMAIL="clips@example.com"
# NOTIFICATIONS_FROM_NAME="Sermon Clipper"
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_MESSAGING_FROM="+15555550100"

# Stripe subscription billing. Required in production to start Checkout, open the Customer Portal,
# and reconcile subscription/webhook events into workspace plans and included-minute grants.
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_STARTER="price_..."
# STRIPE_PRICE_PRO="price_..."

# Optional: override if ffmpeg/ffprobe aren't on PATH. Both default to the bare command name.
# FFMPEG_PATH="ffmpeg"
# FFPROBE_PATH="ffprobe"

# Optional: how often (ms) `npm run worker` polls for queued jobs. Defaults to 2000.
# WORKER_POLL_INTERVAL_MS="2000"

# Optional: worker reliability tuning. Heartbeats mark active jobs, stale recovery requeues or
# fails abandoned work, and retry delays are built into the queue.
# WORKER_ID="worker-1"
# WORKER_HEARTBEAT_INTERVAL_MS="30000"
# WORKER_STALE_JOB_TIMEOUT_MS="900000"
# WORKER_RECOVERY_INTERVAL_MS="60000"

# Real local transcription (whisper.cpp). Required in production. If unset or the file doesn't
# exist, transcription jobs fail clearly with TRANSCRIBE_PROVIDER_UNAVAILABLE instead of faking a
# transcript — see DECISIONS.md. Download a model with whisper.cpp's models/download-ggml-model.sh
# script and make it available on every worker host.
# WHISPER_MODEL_PATH="/path/to/ggml-base.en.bin"
# WHISPER_CPP_BINARY="whisper-cli"

# Real AI clip scoring (claude-haiku-4-5 classification + claude-sonnet-5 scoring/rationale).
# Required in production. If unset outside production, ANALYZE jobs use the deterministic
# heuristic scorer instead (heuristic-v1, clearly labeled non-AI in the UI) rather than faking an
# LLM verdict — see DECISIONS.md.
# ANTHROPIC_API_KEY="sk-ant-..."
