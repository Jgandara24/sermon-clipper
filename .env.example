DATABASE_URL="postgresql://sermon_clipper:sermon_clipper@localhost:5432/sermon_clipper?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Required in production for signed upload, media, and download URLs. Use at least 32 random
# characters and keep it stable across web and worker processes.
# MEDIA_URL_SECRET="change-me-to-a-long-random-production-secret"

# Required for production multi-instance or self-hosted deployments so Server Action references
# remain decryptable across rolling deploys.
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="base64-32-byte-secret"

# Recommended in production so /api/health and launch evidence can prove which commit is deployed.
# Common hosts may also provide VERCEL_GIT_COMMIT_SHA, RAILWAY_GIT_COMMIT_SHA, RENDER_GIT_COMMIT,
# HEROKU_SLUG_COMMIT, GIT_COMMIT_SHA, COMMIT_SHA, or SOURCE_VERSION automatically.
# SERMON_CLIPPER_COMMIT_SHA="git-sha"

# Storage provider. Use "local" for development and "s3" for AWS S3, Cloudflare R2, or any
# S3-compatible object store in production.
STORAGE_PROVIDER="local"

# Local-disk storage root for the dev-only StorageProvider. Defaults to ./.data/storage if unset.
STORAGE_LOCAL_ROOT=".data/storage"

# Required when STORAGE_PROVIDER=s3. For Cloudflare R2, set STORAGE_S3_REGION="auto" and
# STORAGE_S3_ENDPOINT to the account-specific R2 endpoint.
# STORAGE_S3_BUCKET="sermon-clipper-production"
# STORAGE_S3_REGION="auto"
# STORAGE_S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# STORAGE_S3_ACCESS_KEY_ID="..."
# STORAGE_S3_SECRET_ACCESS_KEY="..."
# STORAGE_S3_FORCE_PATH_STYLE="true"

# Required in production (at least 32 characters — readiness fails otherwise). Signs short-lived
# media and upload URLs. Generate with: openssl rand -base64 48
# Local development falls back to a dev-only secret if this is unset. Kept commented out so a
# copy-pasted .env can never ship a known placeholder secret to production.
# MEDIA_URL_SECRET="<long-random-secret-at-least-32-characters>"

# Email OTP sign-in and approval notifications. RESEND_API_KEY plus AUTH_EMAIL_FROM or
# NOTIFICATIONS_FROM_EMAIL is required for production sign-in. If an approval reviewer recipient is
# supplied but credentials are missing, the notification attempt is recorded as skipped.
# RESEND_API_KEY="re_..."
# AUTH_EMAIL_FROM="auth@example.com"
# AUTH_EMAIL_FROM_NAME="Sermon Clipper"
# NOTIFICATIONS_FROM_EMAIL="clips@example.com"
# NOTIFICATIONS_FROM_NAME="Sermon Clipper"
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_MESSAGING_FROM="+15555550100"

# Stripe subscription billing. Required in production to start Checkout, open the Customer Portal,
# and reconcile subscription/webhook events into workspace plans and included-minute grants.
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_STARTER="price_..."
# STRIPE_PRICE_PRO="price_..."

# Optional: override if ffmpeg/ffprobe/yt-dlp aren't on PATH. All default to the bare command name.
# yt-dlp fetches URL-imported source videos (FINALIZE URL branch).
# FFMPEG_PATH="ffmpeg"
# FFPROBE_PATH="ffprobe"
# YTDLP_PATH="yt-dlp"

# Optional: hard timeouts (ms) for media child processes. A process that exceeds its timeout is
# SIGKILLed and the job fails/retries immediately instead of blocking the worker until stale-job
# recovery. Defaults: probe 60s, thumbnail 2m, audio extraction 10m, export pass 15m, ASR 90m,
# URL metadata fetch 30s, URL video download 20m.
# FFPROBE_TIMEOUT_MS="60000"
# FFMPEG_THUMBNAIL_TIMEOUT_MS="120000"
# FFMPEG_AUDIO_EXTRACT_TIMEOUT_MS="600000"
# EXPORT_FFMPEG_TIMEOUT_MS="900000"
# WHISPER_TIMEOUT_MS="5400000"
# YTDLP_METADATA_TIMEOUT_MS="30000"
# YTDLP_DOWNLOAD_TIMEOUT_MS="1200000"

# Optional: how often (ms) `npm run worker` polls for queued jobs. Defaults to 2000.
# WORKER_POLL_INTERVAL_MS="2000"

# Optional: worker reliability tuning. Heartbeats mark active jobs, stale recovery requeues or
# fails abandoned work, and retry delays are built into the queue.
# WORKER_ID="worker-1"
# WORKER_PROCESS_HEARTBEAT_INTERVAL_MS="30000"
# WORKER_HEARTBEAT_MAX_AGE_MS="900000"
# WORKER_HEARTBEAT_INTERVAL_MS="30000"
# WORKER_STALE_JOB_TIMEOUT_MS="900000"
# WORKER_RECOVERY_INTERVAL_MS="60000"

# Optional: retention reaper tuning. The worker scans on this interval (default hourly) and
# enqueues CLEANUP jobs that delete exported MP4s this long (default 30 days) after their
# download link expired, plus an expired project's source media. Database records are kept.
# WORKER_CLEANUP_INTERVAL_MS="3600000"
# EXPORT_FILE_RETENTION_GRACE_MS="2592000000"

# Optional: per-workspace abuse/cost caps on the expensive operations (defaults shown).
# Exports burn worker CPU; each upload can trigger paid transcription/analysis.
# EXPORT_MAX_CONCURRENT_JOBS="4"
# EXPORT_DAILY_JOB_LIMIT="50"
# UPLOAD_PRESIGN_HOURLY_LIMIT="30"

# Optional: external error monitoring (Sentry, errors only). Unset means fully disabled —
# nothing initializes and no events leave the machine. Set on both web and worker in production.
# SENTRY_DSN="https://...@....ingest.sentry.io/..."

# Optional: email the operator when an error-severity operational event is recorded (requires
# RESEND_API_KEY and a from address). Throttled to one email per category:eventType per window
# (default 30 minutes). Unset means no alert emails — events still land in
# /app/settings/operations.
# OPERATIONS_ALERT_EMAIL="you@example.org"
# ALERTS_THROTTLE_MS="1800000"

# Optional: override the Claude models used for clip analysis (defaults shown), so a model
# deprecation is a config change instead of a code deploy. When overriding, also add the new
# model's pricing to src/lib/analysis/usage.ts or spend telemetry will undercount.
# ANALYSIS_MODEL_CLASSIFY="claude-haiku-4-5"
# ANALYSIS_MODEL_SCORING="claude-sonnet-5"

# Real local transcription (whisper.cpp). Required in production. If unset or the file doesn't
# exist, transcription jobs fail clearly with TRANSCRIBE_PROVIDER_UNAVAILABLE instead of faking a
# transcript — see DECISIONS.md. Download a model with whisper.cpp's models/download-ggml-model.sh
# script and make it available on every worker host.
# WHISPER_MODEL_PATH="/path/to/ggml-base.en.bin"
# WHISPER_CPP_BINARY="whisper-cli"

# Real AI clip scoring (claude-haiku-4-5 classification + claude-sonnet-5 scoring/rationale).
# Required in production. If unset outside production, ANALYZE jobs use the deterministic
# heuristic scorer instead (heuristic-v1, clearly labeled non-AI in the UI) rather than faking an
# LLM verdict — see DECISIONS.md.
# ANTHROPIC_API_KEY="sk-ant-..."

# YouTube Data API v3 key for channel auto-import (app-level, like ANTHROPIC_API_KEY — no
# per-workspace OAuth; polls only public channel data). Required for registering channels and
# for the worker's channel polling loop.
# YOUTUBE_API_KEY="youtube-data-api-v3-key"
