DATABASE_URL="postgresql://sermon_clipper:sermon_clipper@localhost:5432/sermon_clipper?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Local-disk storage root for the dev-only StorageProvider (see DECISIONS.md). Defaults to
# ./.data/storage if unset.
STORAGE_LOCAL_ROOT=".data/storage"

# Optional: override if ffmpeg/ffprobe aren't on PATH. Both default to the bare command name.
# FFMPEG_PATH="ffmpeg"
# FFPROBE_PATH="ffprobe"

# Optional: how often (ms) `npm run worker` polls for queued jobs. Defaults to 2000.
# WORKER_POLL_INTERVAL_MS="2000"

# Real local transcription (whisper.cpp). If unset or the file doesn't exist, transcription jobs
# fail clearly with TRANSCRIBE_PROVIDER_UNAVAILABLE instead of faking a transcript — see
# DECISIONS.md. Download a model with whisper.cpp's models/download-ggml-model.sh script.
# WHISPER_MODEL_PATH="/path/to/ggml-base.en.bin"
# WHISPER_CPP_BINARY="whisper-cli"
