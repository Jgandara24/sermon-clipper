{
  "name": "sermon-clipper",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run prisma:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "collect:launch-evidence": "tsx scripts/collect-launch-evidence.ts",
    "create:launch-evidence": "tsx scripts/create-launch-evidence.ts",
    "record:launch-evidence": "tsx scripts/record-launch-evidence.ts",
    "smoke:production": "tsx scripts/production-smoke.ts",
    "verify:launch-evidence": "tsx scripts/verify-launch-evidence.ts",
    "verify": "npm run prisma:validate && npm run lint && npm run typecheck && npm run test && npm run build",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://sermon_clipper:sermon_clipper@localhost:5432/sermon_clipper?schema=public} prisma generate",
    "prisma:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://sermon_clipper:sermon_clipper@localhost:5432/sermon_clipper?schema=public} prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "worker": "tsx watch src/worker/run-jobs.ts",
    "worker:prod": "tsx src/worker/run-jobs.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@aws-sdk/client-s3": "^3.1081.0",
    "@aws-sdk/lib-storage": "^3.1081.0",
    "@aws-sdk/s3-request-presigner": "^3.1081.0",
    "@prisma/client": "^6.19.3",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.3.0",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
